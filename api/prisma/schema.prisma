generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PILOT
  STAFF
  ADMIN
}

enum PilotStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  ON_LEAVE
}

enum PIREPStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FlightPhase {
  PREFLIGHT
  TAXIOUT
  TAKEOFF
  CLIMB
  CRUISE
  DESCENT
  APPROACH
  LANDING
  TAXIIN
  COMPLETE
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  password          String
  role              Role        @default(PILOT)
  isEmailVerified   Boolean     @default(false)
  emailVerifyToken  String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  pilot             Pilot?
  sessions          Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pilot {
  id              String      @id @default(cuid())
  userId          String      @unique
  pilotId         String      @unique
  firstName       String
  lastName        String
  callsign        String?
  avatar          String?
  bio             String?
  simbriefUsername String?
  status          PilotStatus @default(ACTIVE)
  rank            String      @default("Student Pilot")
  totalHours      Float       @default(0)
  totalFlights    Int         @default(0)
  totalDistance   Float       @default(0)
  points          Int         @default(0)
  walletBalance   Float       @default(0)
  bookings        Booking[]
  hub             String?
  joinedAt        DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pireps          PIREP[]
  awards          PilotAward[]
  logbook         LogbookEntry[]
  events          EventAttendee[]
  liveFlight      LiveFlight?
  realisticBookings RealisticFlight[]
}

model Aircraft {
  id           String   @id @default(cuid())
  icao         String
  name         String
  registration String   @unique
  type         String
  engines      String
  pax          Int
  range        Int
  cruiseSpeed  Int
  isActive     Boolean  @default(true)
  hub          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bookings     Booking[]
  pireps       PIREP[]
}

model Route {
  id           String   @id @default(cuid())
  flightNumber String   @unique
  depIcao      String
  arrIcao      String
  depName      String
  arrName      String
  distance     Int
  duration     Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bookings     Booking[]
  pireps       PIREP[]
}

model PIREP {
  id            String      @id @default(cuid())
  pilotId       String
  aircraftId    String
  routeId       String?
  flightNumber  String
  depIcao       String
  arrIcao       String
  depTime       DateTime
  arrTime       DateTime
  flightTime    Float
  distance      Float
  fuelUsed      Float
  landingRate   Int
  status        PIREPStatus @default(PENDING)
  network       String?
  simulator     String
  comments      String?
  staffNotes    String?
  createdAt     DateTime    @default(now())
  bookingId     String?     @unique
  booking       Booking?    @relation(fields: [bookingId], references: [id])
  updatedAt     DateTime    @updatedAt
  pilot         Pilot       @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  aircraft      Aircraft    @relation(fields: [aircraftId], references: [id])
  route         Route?      @relation(fields: [routeId], references: [id])
}

model LogbookEntry {
  id           String   @id @default(cuid())
  pilotId      String
  flightNumber String
  depIcao      String
  arrIcao      String
  date         DateTime
  duration     Float
  aircraft     String
  remarks      String?
  createdAt    DateTime @default(now())
  pilot        Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)
}

model Award {
  id          String       @id @default(cuid())
  name        String       @unique
  description String
  icon        String
  criteria    String
  createdAt   DateTime     @default(now())
  pilots      PilotAward[]
}

model PilotAward {
  id        String   @id @default(cuid())
  pilotId   String
  awardId   String
  awardedAt DateTime @default(now())
  pilot     Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  award     Award    @relation(fields: [awardId], references: [id])

  @@unique([pilotId, awardId])
}

model Hub {
  id        String   @id @default(cuid())
  icao      String   @unique
  name      String
  city      String
  country   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  UPCOMING
  PIREP_PENDING
  APPROVED
  CANCELLED
}

model Booking {
  id              String        @id @default(cuid())
  pilotId         String
  routeId         String
  aircraftId      String
  depTime         DateTime
  network         String
  status          BookingStatus @default(UPCOMING)
  earnings        Float         @default(0)
  simbriefOfpData String?
  simbriefPdfUrl  String?
  simbriefStaticId String?
  simbriefUserId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  pilot           Pilot         @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  route           Route         @relation(fields: [routeId], references: [id])
  aircraft        Aircraft      @relation(fields: [aircraftId], references: [id])
  pirep           PIREP?
}


enum EventStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String
  route       String
  depIcao     String
  arrIcao     String
  date        DateTime
  earnings    Float       @default(0)
  slots       Int         @default(20)
  network     String      @default("Any")
  status      EventStatus @default(UPCOMING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  attendees   EventAttendee[]
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  pilotId   String
  joinedAt  DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pilot     Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  @@unique([eventId, pilotId])
}

// ── ATC SYSTEM ──
enum ATCStatus {
  ACTIVE
  SUSPENDED
}

model ATCController {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  position  String
  rating    String    @default("S1")
  status    ATCStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  schedules ATCSchedule[]
}

model ATCSchedule {
  id        String   @id @default(cuid())
  staffId   String
  date      String
  position  String
  airport   String   @default("DEP")
  timeSlot  String
  status    String   @default("BOOKED")
  createdAt DateTime @default(now())
  staff     ATCController @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date, timeSlot, airport])
}

enum RealisticFlightStatus {
  AVAILABLE
  BOOKED
  COMPLETED
  CANCELLED
}

model RealisticFlight {
  id                 String                  @id @default(cuid())
  flightNumber       String                  @unique
  aircraftType       String                  @default("A320")
  depIcao            String
  arrIcao            String
  depName            String?
  arrName            String?
  offBlock           String
  onBlock            String
  estimatedFlightTime String
  distance           Int
  network            String
  reward             Float                   @default(50)
  date               String
  timeSlot           String
  status             RealisticFlightStatus   @default(AVAILABLE)
  depConfirmed       Boolean                 @default(false)
  arrConfirmed       Boolean                 @default(false)
  pilotId            String?
  bookedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  pilot              Pilot?                  @relation(fields: [pilotId], references: [id])
}

model DailyHub {
  id       String   @id @default(cuid())
  depIcao  String
  arrIcao  String
  depName  String?
  arrName  String?
  date     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LiveFlight {
  id            String      @id @default(cuid())
  pilotId       String      @unique
  bookingId     String?     @unique
  flightNumber  String
  depIcao       String
  arrIcao       String
  aircraftType  String
  lat           Float
  lng           Float
  alt           Int
  heading       Int
  groundSpeed   Int
  phase         FlightPhase @default(PREFLIGHT)
  onlineNetwork String?
  simulator     String?
  lastUpdate    DateTime    @default(now())
  pilot         Pilot       @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  telemetry     Telemetry[]
}

model Telemetry {
  id           String      @id @default(cuid())
  liveFlightId String
  lat          Float
  lng          Float
  alt          Int
  heading      Int
  groundSpeed  Int
  timestamp    DateTime    @default(now())
  liveFlight   LiveFlight  @relation(fields: [liveFlightId], references: [id], onDelete: Cascade)
}